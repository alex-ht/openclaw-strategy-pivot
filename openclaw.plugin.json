{
  "id": "strategy-pivot",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "watchedTools": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["exec"],
        "description": "List of tool names to monitor for failures"
      },
      "minFailuresBeforePivot": {
        "type": "number",
        "default": 1,
        "minimum": 1,
        "description": "Number of consecutive failures before triggering the pivot prompt"
      },
      "promptTemplate": {
        "type": "string",
        "description": "Custom prompt template with {toolName}, {error}, {result} placeholders"
      }
    }
  }
}
