{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",

    "module": "ES2022",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],

    "moduleResolution": "bundler",
    "esModuleInterop": true,

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": ["src"]
}
